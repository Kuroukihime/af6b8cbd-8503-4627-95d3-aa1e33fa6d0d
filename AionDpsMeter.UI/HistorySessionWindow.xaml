<Window x:Class="AionDpsMeter.UI.HistorySessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:h="clr-namespace:AionDpsMeter.UI.ViewModels.History"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=h:HistorySessionViewModel}"
        Title="Session Stats"
        Height="420" Width="680"
        MinHeight="200" MinWidth="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{StaticResource PrimaryBackgroundBrush}"
            BorderBrush="#30363D"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    CornerRadius="5,5,0,0"
                    Padding="10,6"
                    BorderBrush="#21262D" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TargetName}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Run Text="{Binding DateDisplay, Mode=OneWay}" Foreground="{StaticResource SecondaryTextBrush}"/>
                        </TextBlock>
                        <TextBlock FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Run Text="Duration: " Foreground="{StaticResource SecondaryTextBrush}"/>
                            <Run Text="{Binding Duration, Mode=OneWay}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <Border Background="{Binding StateColor, Converter={StaticResource StringToBrushConverter}}"
                                CornerRadius="3" Padding="5,1">
                            <TextBlock Text="{Binding StateLabel}"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBackgroundBrush}"/>
                        </Border>
                    </StackPanel>
                    <Button Content="✕"
                            Width="22" Height="22" FontSize="10"
                            HorizontalAlignment="Right"
                            Click="CloseButton_Click"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#C42B1C" Padding="0"/>
                </Grid>
            </Border>

            <!-- Column headers -->
            <Border Grid.Row="1"
                    Background="{StaticResource TertiaryBackgroundBrush}"
                    BorderBrush="#21262D" BorderThickness="0,0,0,1"
                    Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="1" Text="Player"  FontSize="10" FontWeight="Bold" Foreground="{StaticResource SecondaryTextBrush}"    Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="Damage"  FontSize="10" FontWeight="Bold" Foreground="{StaticResource SecondaryTextBrush}"    HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="3" Text="DPS"     FontSize="10" FontWeight="Bold" Foreground="{StaticResource SecondaryTextBrush}"    HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Crit%"   FontSize="10" FontWeight="Bold" Foreground="{StaticResource CriticalColorBrush}"    HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="Back%"   FontSize="10" FontWeight="Bold" Foreground="{StaticResource BackAttackColorBrush}"  HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="x2%"     FontSize="10" FontWeight="Bold" Foreground="{StaticResource DoubleDamageColorBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="7" Text="Time"    FontSize="10" FontWeight="Bold" Foreground="{StaticResource SecondaryTextBrush}"    HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="8" Text="Share"   FontSize="10" FontWeight="Bold" Foreground="{StaticResource SecondaryTextBrush}"    HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Player list -->
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Players}"
                     Background="Transparent"
                     BorderThickness="0"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     AlternationCount="2">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="{StaticResource PrimaryBackgroundBrush}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#131820"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <!-- Damage % bar background -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                    Background="#253DC9B0" CornerRadius="2">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                        <Binding Path="DamagePercentage"/>
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                            <Border Background="Transparent"
                                    Padding="10,6"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="PlayerItem_Click">
                                <Border.Tag>
                                    <Binding/>
                                </Border.Tag>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1A4EC9B0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="55"/>
                                        <ColumnDefinition Width="55"/>
                                        <ColumnDefinition Width="55"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Class icon -->
                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3"
                                            Background="{StaticResource TertiaryBackgroundBrush}"
                                            Visibility="{Binding HasClassIcon, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Image Source="{Binding ClassIcon, Converter={StaticResource SafeImageSourceConverter}}"
                                               Stretch="Uniform" RenderOptions.BitmapScalingMode="LowQuality"/>
                                    </Border>

                                    <!-- Player name + class -->
                                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="4,0,4,0">
                                        <TextBlock Text="{Binding PlayerNameDisplay}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ClassName}"
                                                   FontSize="9"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </StackPanel>

                                    <!-- Total damage -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TotalDamageDisplay}"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource DamageBarBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>

                                    <!-- DPS -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding DpsDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource DpsColorBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <!-- Crit rate -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding CritRateDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource CriticalColorBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <!-- Back attack rate -->
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding BackAttackRateDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource BackAttackColorBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <!-- Double damage rate -->
                                    <TextBlock Grid.Column="6"
                                               Text="{Binding DoubleDamageRateDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource DoubleDamageColorBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <!-- Duration -->
                                    <TextBlock Grid.Column="7"
                                               Text="{Binding DurationDisplay}"
                                               FontSize="10" FontFamily="Consolas"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <!-- Share % -->
                                    <TextBlock Grid.Column="8"
                                               Text="{Binding DamagePercentDisplay}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
